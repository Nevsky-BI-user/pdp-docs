  "dax": "VAR _seniority = SELECTEDVALUE(fact_employee_seniority_by_month[seniority_LAST_HOLDING_HIRE_DATE])\nVAR _years = ROUNDDOWN(_seniority/12,0)\nVAR _month = _seniority - _years *12\nVAR _res = \n\tIF(\n\t\tNOT ISBLANK( _seniority ),\n\t\tIF(\n\t\t\tNOT ISBLANK( _years ),\n\t\t\t_years & \" р.\"\n\t\t) & \" \" &\n\t\tIF(\n\t\t\tNOT ISBLANK( _month ) && _month <> 0,\n\t\t\t_month & \" міс.\"\n\t\t)\n\t)\nRETURN \n\tCOALESCE(\n\t\tTRIM(_res),\n\t\t\"-\"\n\t)",
