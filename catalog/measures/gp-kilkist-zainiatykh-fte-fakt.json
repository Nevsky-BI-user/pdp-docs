  "dax": "VAR _filter_lt= TREATAS(VALUES( dim_Admin_LT_OS[USER_ACCESS_ID] ), 'fact_Employee_List'[USER_ACCESS_ID])\nVAR _admin = \n\tCALCULATE(\n\t\tSUM('fact_Employee_List'[FTE_employee]),\n\t\t'fact_Employee_List'[status_key] IN { \"1\", \"4\" },\n\t\t'fact_Employee_List'[FTE_employee] > 0\n\t)\nVAR _admin_lt = \n\tCALCULATE(\n\t\tSUM('fact_Employee_List'[FTE_employee]),\n\t\t'fact_Employee_List'[status_key] IN { \"1\", \"4\" },\n\t\t'fact_Employee_List'[FTE_employee] > 0,\n\t\t_filter_lt\n\t)\nVAR _res = \n\tSWITCH(\n\t\tSELECTEDVALUE('t_HierarchyTypes'[Index]),\n\t\t0, _admin_lt,\n\t\t1, _admin\n\t)\nRETURN \n\tTRIM(\n\t\tFORMAT(\n\t\t\t\tCOALESCE(_res, \"-\"), \n\t\t\t\t\"### ###\" \n\t\t) \n\t)",
