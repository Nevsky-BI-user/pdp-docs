& _rH & \"' fill='\" & _cardBg & \"' stroke='\" & _cardBrd & \"' rx='5'/>\" &\n            \"<text class='b' x='\" & _x4 & \"' y='\" & (_yK + 17) & \"'>\" & fact_OKR_SVG[KF_L1_E] & _kfTspans & \"</text>\"\n\n        RETURN _yearLabel & _goal & _kr & _plan & _fact\n    ) &\n    \"</svg>\"\n\nRETURN _htmlHeader & _svgBody",
