  "dax": "VAR _subperson = SELECTEDVALUE('fact_Loss_of_Productivity'[Person_Name])\nVAR _metric_relevance = \n    CALCULATE(\n        MIN('t_Loss_Productivity_Metrics_by_Persona'[Value]),\n        't_Loss_Productivity_Metrics_by_Persona'[SubPerson] = _subperson,\n        't_Loss_Productivity_Metrics_by_Persona'[Metric_Name] = \"Collab_Span_Norm\"\n    )\nVAR _result = \n    SWITCH(\n        SELECTEDVALUE('t_AC Burnout'[Burnout_Indicator]),\n        \"Оцінка\", [AC.Оцінка.Доля взаємодії (Viva) в інтервалі (%)],\n        \"Дані\", [AC.Дані.Доля взаємодії (Viva) в інтервалі (%)]\n    )\nRETURN IF(_metric_relevance = \"NA\", \"NA\", _result)",
