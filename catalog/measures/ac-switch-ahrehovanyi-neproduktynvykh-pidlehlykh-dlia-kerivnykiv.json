  "dax": "VAR _subperson = SELECTEDVALUE('fact_Loss_of_Productivity'[Person_Name])\nVAR _metric_relevance = \n    CALCULATE(\n        MIN('t_Loss_Productivity_Metrics_by_Persona'[Value]),\n        't_Loss_Productivity_Metrics_by_Persona'[SubPerson] = _subperson,\n        't_Loss_Productivity_Metrics_by_Persona'[Metric_Name] = \"Unproductive_Subordinate_Pct\"\n    )\nVAR _result = \n    SWITCH(\n        SELECTEDVALUE('t_AC Burnout'[Burnout_Indicator]),\n        \"Оцінка\", [AC.Оцінка.Агрегований % непродуктинвих підлеглих для керівників],\n        \"Дані\", [AC.Дані.Агрегований % непродуктинвих підлеглих для керівників]\n    )\nRETURN IF(_metric_relevance = \"NA\", \"NA\", _result)",
