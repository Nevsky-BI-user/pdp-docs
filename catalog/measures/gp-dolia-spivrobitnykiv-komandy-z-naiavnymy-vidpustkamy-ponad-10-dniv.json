  "dax": "VAR _filter0 = TREATAS(VALUES( dim_Admin_LT_OS[USER_ACCESS_ID] ), 'fact_Metrics'[USER_ACCESS_ID])\nVAR _admin =\n\tDIVIDE(\n\t\tCALCULATE(\n\t\t\tCOUNTROWS('fact_Metrics'),\n\t\t\t'fact_Metrics'[LONG_VACATION_BY_MAIN_POSITION] > 0\n\t\t),\n\t\tCALCULATE(COUNTROWS('fact_Metrics'))\n\t)\nVAR _admin_lt =\n\tCALCULATE(\n\t\tDIVIDE(\n\t\t\tCALCULATE(\n\t\t\t\tCOUNTROWS('fact_Metrics'),\n\t\t\t\t'fact_Metrics'[LONG_VACATION_BY_MAIN_POSITION] > 0\n\t\t\t),\n\t\t\tCALCULATE(COUNTROWS('fact_Metrics'))\n\t\t),\n\t\t_filter0\n\t)\nVAR _res = \n\tSWITCH(\n\t\tSELECTEDVALUE( t_HierarchyTypes[Index] ),\n\t\t0, _admin_lt,\n\t\t1, _admin\n\t)\nRETURN\n\tTRIM( \n\t\tCOALESCE( \n\t\t\tFORMAT( _res, \"0.00%\" ), \"-\"\n\t\t)\n\t)",
